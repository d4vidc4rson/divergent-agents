{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "random-injection output",
  "description": "Structured output from Random Injection: ideas generated by forcing structural connections from a random word.",
  "type": "object",
  "required": ["skill", "problem_statement", "injections"],
  "additionalProperties": false,
  "properties": {
    "skill": {
      "const": "random-injection"
    },
    "problem_statement": {
      "type": "string",
      "description": "The simplified one-sentence problem statement"
    },
    "injections": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["random_word", "principles", "transfers"],
        "additionalProperties": false,
        "properties": {
          "random_word": {
            "type": "string",
            "description": "The concrete physical noun injected"
          },
          "principles": {
            "type": "array",
            "minItems": 3,
            "maxItems": 5,
            "items": {
              "type": "object",
              "required": ["id", "principle"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^rp\\d+$",
                  "description": "Principle identifier, e.g. rp1, rp2"
                },
                "principle": {
                  "type": "string",
                  "description": "A general mechanism extracted from studying the random word"
                }
              }
            }
          },
          "transfers": {
            "type": "array",
            "minItems": 3,
            "maxItems": 5,
            "items": {
              "type": "object",
              "required": ["id", "source_principle", "idea"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^ri\\d+$",
                  "description": "Transfer idea identifier, e.g. ri1, ri2"
                },
                "source_principle": {
                  "type": "string",
                  "description": "ID of the principle this transfer comes from (e.g. rp1)"
                },
                "idea": {
                  "type": "string",
                  "description": "The transferred idea applied to the problem"
                }
              }
            }
          }
        }
      }
    }
  }
}
